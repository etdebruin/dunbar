{
  "name": "dunbar",
  "version": "0.1.0",
  "description": "A command-line-first social network. Small by design.",
  "type": "module",
  "bin": {
    "dunbar": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "Etienne de Bruin",
  "homepage": "https://github.com/etdebruin/dunbar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etdebruin/dunbar.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "social",
    "social-network",
    "dunbar",
    "terminal"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\nimport{createRequire as _cr}from'module';const require=_cr(import.meta.url);\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@dunbar/server": "workspace:*",
    "@dunbar/shared": "workspace:*",
    "clipanion": "^4.0.0-rc.4",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  }
}
